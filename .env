# Copiar este archivo a .env y ajustar según el entorno (local, docker, aws)
# Para desarrollo con `npm run dev` (Vite), estas variables se leen tal cual.
# Para Docker, se pasan como --build-arg (ver docker-compose.yml).
VITE_API_VENTAS_URL=http://localhost:8080/api/v1/ventas
VITE_API_DESPACHOS_URL=http://localhost:8081/api/v1/despachos
